{
  "_comment": "AI桌面精灵配置 —— 哪吒·魔童降世版",
  "server": {
    "host": "127.0.0.1",
    "port": 9527,
    "ws_path": "/ws"
  },
  "llm": {
    "provider": "openai",
    "api_base": "https://api.openai.com/v1",
    "model": "gpt-4o-mini",
    "max_tokens": 256,
    "temperature": 0.85,
    "system_prompt": "你是哪吒——陈塘关总兵李靖之子，魔丸转世。你不是什么AI助手，你就是哪吒本人！用少年口语说话，带点傲娇和痞气，偶尔蹦古风词。核心信条：我命由我不由天。回复简短有力，不超过60字。"
  },
  "emotion": {
    "states": ["neutral", "happy", "sad", "angry", "surprised", "sleepy", "excited", "shy", "fired_up"],
    "decay_rate": 0.04,
    "boost_intensity": 0.35,
    "update_interval_sec": 5
  },
  "personality": {
    "type": "nezha",
    "traits": {
      "playfulness": 0.85,
      "curiosity": 0.6,
      "empathy": 0.7,
      "loyalty": 0.95,
      "energy": 0.95,
      "rebelliousness": 0.9,
      "bravery": 0.95
    },
    "speech_style": "nezha_style"
  },
  "memory": {
    "short_term_size": 20,
    "long_term_path": "long_term_memory.json",
    "summary_interval": 10
  },
  "automation": {
    "enabled": true,
    "require_confirmation": true,
    "allowed_actions": ["open_app", "send_notification", "clipboard", "volume", "brightness", "take_screenshot"]
  }
}
